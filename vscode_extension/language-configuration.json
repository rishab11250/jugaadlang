{
  "comments": {
    "lineComment": "#",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] },
    { "open": "\"\"\"", "close": "\"\"\"", "notIn": ["string", "comment"] },
    { "open": "'''", "close": "'''", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"],
    ["`", "`"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^((?!#).)*:\\s*$",
    "decreaseIndentPattern": "^\\s*(warna|shayad|gadbad|aakhir_me)\\b.*:\\s*$"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*(?:banao|ustad|agar|shayad|warna|ghumo|jabtak|koshish|gadbad|aakhir_me)\\b.*:\\s*$",
      "action": {
        "indent": "indent"
      }
    },
    {
      "beforeText": "^\\s*#.*$",
      "action": {
        "indent": "none",
        "appendText": "# "
      }
    }
  ],
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "folding": {
    "offSide": true
  }
}
