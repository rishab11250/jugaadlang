{
  "name": "jugaadlang",
  "displayName": "JugaadLang",
  "description": "JugaadLang \u2014 Hindi-keyword programming language support for VS Code",
  "version": "1.1.5",
  "publisher": "jugaadlang",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Formatters"
  ],
  "keywords": [
    "jugaadlang",
    "hindi",
    "jug",
    "indian programming language",
    "roman hindi",
    "desi coding"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jugaadlang/jugaadlang"
  },
  "license": "MIT",
  "activationEvents": [
    "onLanguage:jugaadlang"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "jugaadlang",
        "aliases": [
          "JugaadLang",
          "jug"
        ],
        "extensions": [
          ".jug"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./assets/icon.png",
          "dark": "./assets/icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "jugaadlang",
        "scopeName": "source.jug",
        "path": "./syntaxes/jugaadlang.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "jugaadlang",
        "path": "./snippets/jugaadlang.json"
      }
    ],
    "commands": [
      {
        "command": "jugaadlang.runFile",
        "title": "JugaadLang: Run File",
        "icon": "$(play)"
      },
      {
        "command": "jugaadlang.openRepl",
        "title": "JugaadLang: Open REPL",
        "icon": "$(terminal)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "jugaadlang.runFile",
          "when": "resourceLangId == jugaadlang",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "jugaadlang.runFile",
        "key": "ctrl+f5",
        "mac": "cmd+f5",
        "when": "resourceLangId == jugaadlang"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "JugaadLang",
      "properties": {
        "jugaadlang.jugPath": {
          "type": "string",
          "default": "jug",
          "description": "Path to the jug executable"
        },
        "jugaadlang.showWelcomeMessage": {
          "type": "boolean",
          "default": true,
          "description": "Show welcome message when a .jug file is first opened"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "typescript": "^5.3.0"
  }
}
