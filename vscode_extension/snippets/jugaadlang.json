    ],
    "description": "...se lao \u2192 Python: from ... import ..."
  },
  "Generator Function": {
    "prefix": "baanto",
    "body": [
      "banao ${1:generator}(${2:n}):",
      "\t\"\"\"Generator function \u2014 ek ek karke deta hai!\"\"\"",
      "\tghumo ${3:i} mein range(${2:n}):",
      "\t\tbaanto ${3:i}"
    ],
    "description": "baanto \u2192 Python: yield (generator)"
  },
  "Context Manager": {
    "prefix": "ke-saath",
    "body": [
      "ke_saath ${1:open('file.txt', 'r')} jaise ${2:f}:",
      "\t${3:content} = ${2:f}.read()",
      "\tbolo(${3:content})"
    ],
    "description": "ke_saath \u2192 Python: with ... as ..."
  },
  "Dataclass": {
    "prefix": "data-ustad",
    "body": [
      "lao dataclasses se dataclass, field",
      "",
      "@dataclass",
      "ustad ${1:DataClass}:",
      "\t\"\"\"${2:Data class \u2014 clean aur simple!}\"\"\"",
      "\t${3:name}: str = ''",
      "\t${4:value}: int = 0",
      "\t${5:items}: list = field(default_factory=list)"
    ],
    "description": "Dataclass \u2192 Python @dataclass"
  },
  "Type Hints": {
    "prefix": "banao-typed",
    "body": [
