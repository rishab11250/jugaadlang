{
  "Print Statement": {
    "prefix": "bolo",
    "body": ["bolo(\"$1\")$0"],
    "description": "bolo(\"...\") → Python: print(\"...\")"
  },
  "If Statement": {
    "prefix": "agar",
    "body": [
      "agar ${1:condition}:",
      "\t${2:theek_hai}"
    ],
    "description": "agar ... → Python: if ..."
  },
  "If-Else Statement": {
    "prefix": "agar-warna",
    "body": [
      "agar ${1:condition}:",
      "\t${2:theek_hai}",
      "warna:",
      "\t${3:theek_hai}"
    ],
    "description": "agar...warna → Python: if...else"
  },
  "If-Elif-Else Statement": {
    "prefix": "agar-shayad-warna",
    "body": [
      "agar ${1:condition}:",
      "\t${2:theek_hai}",
      "shayad ${3:other_condition}:",
      "\t${4:theek_hai}",
      "warna:",
      "\t${5:theek_hai}"
    ],
    "description": "agar...shayad...warna → Python: if...elif...else"
  },
  "Function Definition": {
    "prefix": "banao",
    "body": [
      "banao ${1:function_name}(${2:params}):",
      "\t\"\"\"${3:Yaha likho apna documentation. Ekdum mast!}\"\"\"",
      "\t${4:theek_hai}",
      "\twapas ${5:kuch_nahi}"
    ],
    "description": "banao ... → Python: def ..."
  },
  "Async Function Definition": {
    "prefix": "tez-banao",
    "body": [
      "tez banao ${1:function_name}(${2:params}):",
      "\t\"\"\"${3:Async wala function — thoda intezaar karo!}\"\"\"",
      "\t${4:result} = intezaar ${5:coroutine}",
      "\twapas ${4:result}"
    ],
    "description": "tez banao → Python: async def"
  },
  "Class Definition": {
    "prefix": "ustad",
    "body": [
      "ustad ${1:ClassName}(${2:object}):",
      "\t\"\"\"${3:Yeh hai hamara ustad class!}\"\"\"",
      "",
      "\tbanao shuru(khud${4:, ${5:param}}):",
      "\t\tkhud.${6:attribute} = ${7:value}",
      "",
      "\tbanao ${8:method_name}(khud):",
      "\t\twapas khud.${6:attribute}"
    ],
    "description": "ustad → Python: class"
  },
  "Class with Inheritance": {
    "prefix": "class-inherit",
    "body": [
      "ustad ${1:ChildClass}(${2:ParentClass}):",
      "\t\"\"\"${3:Beta class jo inherit karti hai parent se!}\"\"\"",
      "",
      "\tbanao shuru(khud${4:, ${5:param}}):",
      "\t\tsuper().__init__(${6})",
      "\t\tkhud.${7:attribute} = ${8:value}",
      "",
      "\tbanao ${9:method_name}(khud):",
      "\t\twapas super().${9:method_name}()"
    ],
    "description": "ustad with inheritance → Python: class Child(Parent)"
  },
  "For Loop": {
    "prefix": "ghumo",
    "body": [
      "ghumo ${1:item} mein ${2:iterable}:",
      "\t${3:theek_hai}"
    ],
    "description": "ghumo...mein → Python: for...in"
  },
  "For Loop with Range": {
    "prefix": "ghumo-range",
    "body": [
      "ghumo ${1:i} mein range(${2:10}):",
      "\t${3:bolo(${1:i})}"
    ],
    "description": "ghumo...mein range() → Python: for i in range()"
  },
  "While Loop": {
    "prefix": "jabtak",
    "body": [
      "jabtak ${1:condition}:",
      "\t${2:theek_hai}"
    ],
    "description": "jabtak → Python: while"
  },
  "Try-Except": {
    "prefix": "koshish",
    "body": [
      "koshish:",
      "\t${1:# koshish karo}",
      "gadbad ${2:Exception} jaise ${3:e}:",
      "\t${4:bolo(f\"Gadbad ho gayi: {${3:e}}\")}"
    ],
    "description": "koshish...gadbad → Python: try...except"
  },
  "Try-Except-Finally": {
    "prefix": "koshish-aakhir",
    "body": [
      "koshish:",
      "\t${1:# koshish karo}",
      "gadbad ${2:Exception} jaise ${3:e}:",
      "\t${4:bolo(f\"Gadbad ho gayi: {${3:e}}\")}",
      "aakhir_me:",
      "\t${5:# hamesha chalta hai}"
    ],
    "description": "koshish...gadbad...aakhir_me → Python: try...except...finally"
  },
  "Try-Except-Else-Finally": {
    "prefix": "koshish-full",
    "body": [
      "koshish:",
      "\t${1:# risky code}",
      "gadbad ${2:ValueError} jaise ${3:e}:",
      "\t${4:bolo(f\"Yeh gadbad aayi: {${3:e}}\")}",
      "warna:",
      "\t${5:# sab sahi tha}",
      "aakhir_me:",
      "\t${6:# cleanup karo}"
    ],
    "description": "Full try-except-else-finally → Python equivalent"
  },
  "Lambda Function": {
    "prefix": "chota_funkshan",
    "body": [
      "chota_funkshan ${1:x}: ${2:x * 2}"
    ],
    "description": "chota_funkshan → Python: lambda"
  },
  "Main Boilerplate": {
    "prefix": "main",
    "body": [
      "# ${1:Main entry point — JugaadLang mein swagat hai!}",
      "",
      "banao ${2:main}():",
      "\t\"\"\"Main function — yahan se shuru hota hai sab kuch.\"\"\"",
      "\t${3:bolo(\"Jai JugaadLang!\")}",
      "",
      "agar __name__ == \"__main__\":",
      "\t${2:main}()"
    ],
    "description": "Main boilerplate — Python: if __name__ == '__main__'"
  },
  "Hello World": {
    "prefix": "hello",
    "body": [
      "# JugaadLang mein pehla program!",
      "bolo(\"Namaste Duniya! 🇮🇳\")"
    ],
    "description": "Hello World in JugaadLang — Namaste Duniya!"
  },
  "Fibonacci Function": {
    "prefix": "fibonacci",
    "body": [
      "banao fibonacci(n):",
      "\t\"\"\"Fibonacci sequence — desi andaz mein!\"\"\"",
      "\tagar n <= 1:",
      "\t\twapas n",
      "\twapas fibonacci(n - 1) + fibonacci(n - 2)",
      "",
      "# Pehle 10 fibonacci numbers print karo",
      "ghumo i mein range(10):",
      "\tbolo(f\"fibonacci({i}) = {fibonacci(i)}\")"
    ],
    "description": "Fibonacci function in JugaadLang"
  },
  "Basic Flask API": {
    "prefix": "api",
    "body": [
      "lao flask se Flask, jsonify, request",
      "",
      "app = Flask(__name__)",
      "",
      "@app.route('/${1:endpoint}', methods=['GET'])",
      "banao ${2:get_data}():",
      "\t\"\"\"${3:API endpoint — desi jugaad!}\"\"\"",
      "\tdata = {",
      "\t\t'${4:message}': '${5:Jai JugaadLang!}',",
      "\t\t'sahi': sahi",
      "\t}",
      "\twapas jsonify(data)",
      "",
      "agar __name__ == '__main__':",
      "\tapp.run(debug=sahi)"
    ],
    "description": "Basic Flask API → Python Flask boilerplate"
  },
  "List Comprehension": {
    "prefix": "list-ghumo",
    "body": [
      "${1:result} = [${2:expression} ghumo ${3:item} mein ${4:iterable}]"
    ],
    "description": "List comprehension → Python: [expr for item in iterable]"
  },
  "Dict Comprehension": {
    "prefix": "dict-ghumo",
    "body": [
      "${1:result} = {${2:key}: ${3:value} ghumo ${4:item} mein ${5:iterable}}"
    ],
    "description": "Dict comprehension → Python: {k: v for item in iterable}"
  },
  "Import Statement": {
    "prefix": "lao",
    "body": [
      "lao ${1:module}"
    ],
    "description": "lao → Python: import"
  },
  "From Import": {
    "prefix": "se-lao",
    "body": [
      "${1:module} se lao ${2:name}"
    ],
    "description": "...se lao → Python: from ... import ..."
  },
  "Generator Function": {
    "prefix": "baanto",
    "body": [
      "banao ${1:generator}(${2:n}):",
      "\t\"\"\"Generator function — ek ek karke deta hai!\"\"\"",
      "\tghumo ${3:i} mein range(${2:n}):",
      "\t\tbaanto ${3:i}"
    ],
    "description": "baanto → Python: yield (generator)"
  },
  "Context Manager": {
    "prefix": "ke-saath",
    "body": [
      "ke_saath ${1:open('file.txt', 'r')} jaise ${2:f}:",
      "\t${3:content} = ${2:f}.read()",
      "\tbolo(${3:content})"
    ],
    "description": "ke_saath → Python: with ... as ..."
  },
  "Dataclass": {
    "prefix": "data-ustad",
    "body": [
      "lao dataclasses se dataclass, field",
      "",
      "@dataclass",
      "ustad ${1:DataClass}:",
      "\t\"\"\"${2:Data class — clean aur simple!}\"\"\"",
      "\t${3:name}: str = ''",
      "\t${4:value}: int = 0",
      "\t${5:items}: list = field(default_factory=list)"
    ],
    "description": "Dataclass → Python @dataclass"
  },
  "Type Hints": {
    "prefix": "banao-typed",
    "body": [
      "banao ${1:function}(${2:param}: ${3:str}) -> ${4:str}:",
      "\t\"\"\"${5:Type-hinted function!}\"\"\"",
      "\twapas ${2:param}"
    ],
    "description": "Function with type hints"
  },
  "Assert Statement": {
    "prefix": "pakka",
    "body": [
      "assert ${1:condition}, \"${2:Yeh condition fail ho gayi!\""
    ],
    "description": "assert → Python: assert (pakka matlab 'make sure')"
  },
  "Delete Statement": {
    "prefix": "hatao",
    "body": [
      "del ${1:variable}"
    ],
    "description": "del → Python: del (hatao = remove)"
  },
  "Property Decorator": {
    "prefix": "property-banao",
    "body": [
      "@property",
      "banao ${1:attribute}(khud):",
      "\t\"\"\"Get ${1:attribute}.\"\"\"",
      "\twapas khud._${1:attribute}",
      "",
      "@${1:attribute}.setter",
      "banao ${1:attribute}(khud, value):",
      "\t\"\"\"Set ${1:attribute}.\"\"\"",
      "\tkhud._${1:attribute} = value"
    ],
    "description": "Property getter/setter → Python @property"
  }
}
