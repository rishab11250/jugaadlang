{
  "Print Statement": {
    "prefix": "bolo",
    "body": [
      "bolo(\"$1\")$0"
    ],
    "description": "bolo(\"...\") \u2192 Python: print(\"...\")"
  },
  "If Statement": {
    "prefix": "agar",
    "body": [
      "agar ${1:condition}:",
      "\t${2:theek_hai}"
    ],
    "description": "agar ... \u2192 Python: if ..."
  },
  "If-Else Statement": {
    "prefix": "agar-warna",
    "body": [
      "agar ${1:condition}:",
      "\t${2:theek_hai}",
      "warna:",
      "\t${3:theek_hai}"
    ],
    "description": "agar...warna \u2192 Python: if...else"
  },
  "If-Elif-Else Statement": {
    "prefix": "agar-shayad-warna",
    "body": [
      "agar ${1:condition}:",
      "\t${2:theek_hai}",
      "shayad ${3:other_condition}:",
      "\t${4:theek_hai}",
      "warna:",
      "\t${5:theek_hai}"
    ],
    "description": "agar...shayad...warna \u2192 Python: if...elif...else"
  },
  "Function Definition": {
    "prefix": "banao",
    "body": [
      "banao ${1:function_name}(${2:params}):",
      "\t\"\"\"${3:Yaha likho apna documentation. Ekdum mast!}\"\"\"",
      "\t${4:theek_hai}",
      "\twapas ${5:kuch_nahi}"
    ],
    "description": "banao ... \u2192 Python: def ..."
  },
  "Async Function Definition": {
    "prefix": "tez-banao",
    "body": [
      "tez banao ${1:function_name}(${2:params}):",
      "\t\"\"\"${3:Async wala function \u2014 thoda intezaar karo!}\"\"\"",
      "\t${4:result} = intezaar ${5:coroutine}",
      "\twapas ${4:result}"
    ],
    "description": "tez banao \u2192 Python: async def"
  },
  "Class Definition": {
    "prefix": "ustad",
    "body": [
      "ustad ${1:ClassName}(${2:object}):",
      "\t\"\"\"${3:Yeh hai hamara ustad class!}\"\"\"",
      "",
      "\tbanao shuru(khud${4:, ${5:param}}):",
      "\t\tkhud.${6:attribute} = ${7:value}",
      "",
      "\tbanao ${8:method_name}(khud):",
      "\t\twapas khud.${6:attribute}"
    ],
    "description": "ustad \u2192 Python: class"
  },
  "Class with Inheritance": {
    "prefix": "class-inherit",
    "body": [
      "ustad ${1:ChildClass}(${2:ParentClass}):",
      "\t\"\"\"${3:Beta class jo inherit karti hai parent se!}\"\"\"",
      "",
      "\tbanao shuru(khud${4:, ${5:param}}):",
      "\t\tsuper().__init__(${6})",
      "\t\tkhud.${7:attribute} = ${8:value}",
      "",
      "\tbanao ${9:method_name}(khud):",
      "\t\twapas super().${9:method_name}()"
    ],
    "description": "ustad with inheritance \u2192 Python: class Child(Parent)"
  },
  "For Loop": {
    "prefix": "ghumo",
    "body": [
      "ghumo ${1:item} mein ${2:iterable}:",
      "\t${3:theek_hai}"
    ],
    "description": "ghumo...mein \u2192 Python: for...in"
  },
  "For Loop with Range": {
    "prefix": "ghumo-range",
    "body": [
      "ghumo ${1:i} mein range(${2:10}):",
      "\t${3:bolo(${1:i})}"
    ],
    "description": "ghumo...mein range() \u2192 Python: for i in range()"
  },
  "While Loop": {
    "prefix": "jabtak",
    "body": [
      "jabtak ${1:condition}:",
      "\t${2:theek_hai}"
    ],
    "description": "jabtak \u2192 Python: while"
  },
  "Try-Except": {
    "prefix": "koshish",
    "body": [
      "koshish:",
      "\t${1:# koshish karo}",
      "gadbad ${2:Exception} jaise ${3:e}:",
      "\t${4:bolo(f\"Gadbad ho gayi: {${3:e}}\")}"
    ],
    "description": "koshish...gadbad \u2192 Python: try...except"
  },
  "Try-Except-Finally": {
    "prefix": "koshish-aakhir",
    "body": [
      "koshish:",
      "\t${1:# koshish karo}",
      "gadbad ${2:Exception} jaise ${3:e}:",
      "\t${4:bolo(f\"Gadbad ho gayi: {${3:e}}\")}",
      "aakhir_me:",
      "\t${5:# hamesha chalta hai}"
    ],
    "description": "koshish...gadbad...aakhir_me \u2192 Python: try...except...finally"
  },
  "Try-Except-Else-Finally": {
    "prefix": "koshish-full",
    "body": [
      "koshish:",
      "\t${1:# risky code}",
      "gadbad ${2:ValueError} jaise ${3:e}:",
      "\t${4:bolo(f\"Yeh gadbad aayi: {${3:e}}\")}",
      "warna:",
      "\t${5:# sab sahi tha}",
      "aakhir_me:",
      "\t${6:# cleanup karo}"
    ],
    "description": "Full try-except-else-finally \u2192 Python equivalent"
  },
  "Lambda Function": {
    "prefix": "chota_funkshan",
    "body": [
      "chota_funkshan ${1:x}: ${2:x * 2}"
    ],
    "description": "chota_funkshan \u2192 Python: lambda"
  },
  "Main Boilerplate": {
    "prefix": "main",
    "body": [
      "# ${1:Main entry point \u2014 JugaadLang mein swagat hai!}",
      "",
      "banao ${2:main}():",
      "\t\"\"\"Main function \u2014 yahan se shuru hota hai sab kuch.\"\"\"",
      "\t${3:bolo(\"Jai JugaadLang!\")}",
      "",
      "agar __name__ == \"__main__\":",
      "\t${2:main}()"
    ],
    "description": "Main boilerplate \u2014 Python: if __name__ == '__main__'"
  },
  "Hello World": {
    "prefix": "hello",
    "body": [
      "# JugaadLang mein pehla program!",
      "bolo(\"Namaste Duniya! \ud83c\uddee\ud83c\uddf3\")"
    ],
    "description": "Hello World in JugaadLang \u2014 Namaste Duniya!"
  },
  "Fibonacci Function": {
    "prefix": "fibonacci",
    "body": [
      "banao fibonacci(n):",
      "\t\"\"\"Fibonacci sequence \u2014 desi andaz mein!\"\"\"",
      "\tagar n <= 1:",
      "\t\twapas n",
      "\twapas fibonacci(n - 1) + fibonacci(n - 2)",
      "",
      "# Pehle 10 fibonacci numbers print karo",
      "ghumo i mein range(10):",
      "\tbolo(f\"fibonacci({i}) = {fibonacci(i)}\")"
    ],
    "description": "Fibonacci function in JugaadLang"
  },
  "Basic Flask API": {
    "prefix": "api",
    "body": [
      "lao flask se Flask, jsonify, request",
      "",
      "app = Flask(__name__)",
      "",
      "@app.route('/${1:endpoint}', methods=['GET'])",
      "banao ${2:get_data}():",
      "\t\"\"\"${3:API endpoint \u2014 desi jugaad!}\"\"\"",
      "\tdata = {",
      "\t\t'${4:message}': '${5:Jai JugaadLang!}',",
      "\t\t'sahi': sahi",
      "\t}",
      "\twapas jsonify(data)",
      "",
      "agar __name__ == '__main__':",
      "\tapp.run(debug=sahi)"
    ],
    "description": "Basic Flask API \u2192 Python Flask boilerplate"
  },
  "List Comprehension": {
    "prefix": "list-ghumo",
    "body": [
      "${1:result} = [${2:expression} ghumo ${3:item} mein ${4:iterable}]"
    ],
    "description": "List comprehension \u2192 Python: [expr for item in iterable]"
  },
  "Dict Comprehension": {
    "prefix": "dict-ghumo",
    "body": [
      "${1:result} = {${2:key}: ${3:value} ghumo ${4:item} mein ${5:iterable}}"
    ],
    "description": "Dict comprehension \u2192 Python: {k: v for item in iterable}"
  },
  "Import Statement": {
    "prefix": "lao",
    "body": [
