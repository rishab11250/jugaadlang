  "Property Decorator": {
    "prefix": "property-banao",
    "body": [
      "@property",
      "banao ${1:attribute}(khud):",
      "\t\"\"\"Get ${1:attribute}.\"\"\"",
      "\twapas khud._${1:attribute}",
      "",
      "@${1:attribute}.setter",
      "banao ${1:attribute}(khud, value):",
      "\t\"\"\"Set ${1:attribute}.\"\"\"",
      "\tkhud._${1:attribute} = value"
    ],
    "description": "Property getter/setter \u2192 Python @property"
  },
